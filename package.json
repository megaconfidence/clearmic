{
  "name": "clearmic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.worker.json && tsc -p tsconfig.app.json",
    "r2:cors": "bash r2-cors.sh && wrangler r2 bucket cors set clearmic-audio --file r2-cors.json --force",
    "db:migrate:local": "wrangler d1 migrations apply clearmic-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply clearmic-db --remote",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.39.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
